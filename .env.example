# AI Provider Configuration (可选 doubao, openai, anthropic, deepseek)
AI_PROVIDER=doubao

# AI Service API KEY (适用于所有提供商)
# 豆包获取: https://console.volcengine.com/ark/region:ark+cn-beijing/endpoint
API_KEY=your_api_key_here

# 模型接入点 ID (Endpoint ID) 或模型名称
# 豆包示例: doubao-seed-2-0-mini-260215
# OpenAI 示例: gpt-4o
MODEL_ID=doubao-seed-2-0-mini-260215

# OpenAI 代理地址 (可选)
# OPENAI_BASE_URL=https://api.openai.com/v1

# 管理员登录密码
ADMIN_PASSWORD=admin456

# 构建时路径前缀 (例如 /dashboard，默认为空)
NEXT_PUBLIC_BASE_PATH=
